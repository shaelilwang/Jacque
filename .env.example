# Copy to .env and fill in your keys.
CHANNEL3_API_KEY=your_channel3_api_key_here

# Used by the "Fill description (Sonnet)" text-assist step.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Used by the scoped-site search harness (Google Programmable Search).
# Create a Programmable Search Engine set to "Search the entire web" -> cx,
# and an API key for the Custom Search JSON API.
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_search_engine_id_here
